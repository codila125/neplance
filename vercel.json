{
  "version": 2,

  "rewrites": [
    {
      "source": "/backend/:path*",
      "destination": "https://neplance.onrender.com*"
    }
  ],
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ],
  "env": {}
}
